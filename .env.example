# =========================================================
# OfferPilot 本地开发环境变量模板（提交到仓库）
# 说明：
# 1) 复制本文件为 .env 后再填写敏感值
# 2) 敏感字段（API Key、邮箱密码、Webhook）请勿提交
# 3) 后端启动示例：uvicorn app.main:app --env-file "..\.env" --reload --host 127.0.0.1 --port 8010
# =========================================================

# -------------------------
# [模块 1] LLM 模型配置
# -------------------------
# 主推：DashScope(Qwen)；可保留 DeepSeek 作为备用
DASHSCOPE_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_PRIMARY=qwen3-max
MODEL_FALLBACK=qwen-plus

# 可选：覆盖默认简历画像（用于匹配评分）
# RESUME_PROFILE_TEXT=...


# -------------------------
# [模块 2] API 运行与跨域
# -------------------------
ENV=dev
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000


# -------------------------
# [模块 3] 数据存储（PostgreSQL + Chroma）
# -------------------------
DATABASE_URL=postgresql://postgres:offerpilot@localhost:15433/offerpilot
LANGGRAPH_CHECKPOINT_DATABASE_URL=postgresql://postgres:offerpilot@localhost:15433/offerpilot

CHROMA_DIR=./chroma_db
CHROMA_JD_HISTORY_COLLECTION=jd_history
CHROMA_RESUME_COLLECTION=resume_chunks
LOCAL_EMBED_DIM=256
JD_HISTORY_MIN_SIMILARITY=0.35


# -------------------------
# [模块 4] 材料生成与导出
# -------------------------
MATERIAL_MIN_MATCH_SCORE=60
MATERIAL_EXPORT_DIR=./backend/exports/materials


# -------------------------
# [模块 5] BOSS 浏览器自动化
# -------------------------
# 本地调试建议 false（可见浏览器），容器内建议 true
BOSS_HEADLESS=false
BOSS_BROWSER_PROFILE_DIR=./backend/.playwright/boss
BOSS_SCREENSHOT_DIR=./backend/exports/screenshots
BOSS_ENABLE_STEALTH=true
BOSS_ACTION_DELAY_MIN_MS=3000
BOSS_ACTION_DELAY_MAX_MS=5000
BOSS_FETCH_DETAIL=false
FORM_AUTOFILL_TIMEOUT_MS=20000


# -------------------------
# [模块 6] BOSS 对话 Copilot
# -------------------------
BOSS_CHAT_SOURCE_FIT_THRESHOLD=65
BOSS_CHAT_PROACTIVE_MATCH_THRESHOLD=70
BOSS_CHAT_PROACTIVE_JD_ENRICHMENT=true
BOSS_CHAT_CONFIDENCE_THRESHOLD=0.7

# 自动发送双开关之一（另一个是请求体 auto_execute=true）
BOSS_CHAT_AUTO_EXECUTE_ENABLED=false

# 可选：当 BOSS 页面结构变动时，覆盖输入框/发送按钮选择器
# BOSS_CHAT_INPUT_SELECTORS=.input-area,[contenteditable=true],textarea.chat-input
# BOSS_CHAT_SEND_SELECTORS=.send-message,.send-btn


# -------------------------
# [模块 7] 邮件 IMAP（可选）
# -------------------------
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=


# -------------------------
# [模块 8] 邮件心跳与通知
# -------------------------
EMAIL_HEARTBEAT_ENABLED=false
EMAIL_HEARTBEAT_INTERVAL_SEC=1800
EMAIL_HEARTBEAT_MAX_ITEMS=10
EMAIL_HEARTBEAT_MARK_SEEN=false
EMAIL_HEARTBEAT_NOTIFY_ON_UPDATES=true

EMAIL_SCHEDULE_REMINDER_HOURS=24
EMAIL_SCHEDULE_UPCOMING_DAYS=14

NOTIFY_WEBHOOK_URL=
NOTIFY_MODE=feishu_card
NOTIFY_TIMEOUT_SEC=8


# -------------------------
# [模块 9] 公司情报 Web 搜索（可选）
# -------------------------
WEB_SEARCH_PROVIDER=auto
WEB_SEARCH_TIMEOUT_SEC=10
WEB_SEARCH_MAX_RESULTS=6
TAVILY_API_KEY=


# -------------------------
# [模块 10] 前端提示
# -------------------------
# Next.js 本地开发建议单独写到 frontend/.env.local：
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010
