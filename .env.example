# =========================================================
# Pulse 本地开发环境变量模板（提交到仓库）
# 说明：
# 1) 复制本文件为 .env 后再填写敏感值
# 2) 敏感字段（API Key、邮箱密码、Webhook）请勿提交
# 3) 后端启动示例：uvicorn pulse.core.server:create_app --factory --env-file ".env" --reload --host 127.0.0.1 --port 8010
# =========================================================

# -------------------------
# [模块 1] LLM 模型配置
# -------------------------
# 主推：DashScope(Qwen)；可保留 DeepSeek 作为备用
DASHSCOPE_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_PRIMARY=qwen-plus
MODEL_FALLBACK=qwen3-max

# 按业务链路路由模型（可选，不填则走 MODEL_PRIMARY / MODEL_FALLBACK）
# 核心决策链路：质量优先 + 成本平衡
MODEL_ROUTE_JD_ANALYSIS_PRIMARY=qwen-plus
MODEL_ROUTE_JD_ANALYSIS_FALLBACK=qwen3-max
# 主动打招呼最终决策：优先准确率（避免误打），使用 Max -> Plus
MODEL_ROUTE_GREET_DECISION_PRIMARY=qwen3-max
MODEL_ROUTE_GREET_DECISION_FALLBACK=qwen-plus

# 对话轻决策链路：先低成本，再回退
MODEL_ROUTE_CHAT_CLASSIFY_PRIMARY=qwen-turbo
MODEL_ROUTE_CHAT_CLASSIFY_FALLBACK=qwen-plus
MODEL_ROUTE_CHAT_PLAN_PRIMARY=qwen-turbo
MODEL_ROUTE_CHAT_PLAN_FALLBACK=qwen-plus
MODEL_ROUTE_PROACTIVE_CONTACT_PRIMARY=qwen-turbo
MODEL_ROUTE_PROACTIVE_CONTACT_FALLBACK=qwen-plus

# 对话高质量回复链路
MODEL_ROUTE_CHAT_REPLY_PRIMARY=qwen-plus
MODEL_ROUTE_CHAT_REPLY_FALLBACK=qwen3-max

# 其他模块
MODEL_ROUTE_SOURCE_FIT_PRIMARY=qwen-plus
MODEL_ROUTE_SOURCE_FIT_FALLBACK=qwen3-max
MODEL_ROUTE_EMAIL_CLASSIFY_PRIMARY=qwen-turbo
MODEL_ROUTE_EMAIL_CLASSIFY_FALLBACK=qwen-plus
MODEL_ROUTE_MATERIAL_DRAFT_PRIMARY=qwen-plus
MODEL_ROUTE_MATERIAL_DRAFT_FALLBACK=qwen3-max
MODEL_ROUTE_COMPANY_INTEL_PRIMARY=qwen-plus
MODEL_ROUTE_COMPANY_INTEL_FALLBACK=qwen3-max
MODEL_ROUTE_INTERVIEW_PREP_PRIMARY=qwen-plus
MODEL_ROUTE_INTERVIEW_PREP_FALLBACK=qwen3-max

# 可选：覆盖默认简历画像（用于匹配评分）
# RESUME_PROFILE_TEXT=...


# -------------------------
# [模块 2] API 运行与跨域
# -------------------------
ENV=dev
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000


# -------------------------
# [模块 3] 数据存储（PostgreSQL + Chroma）
# -------------------------
DATABASE_URL=postgresql://postgres:pulse@localhost:15433/pulse
LANGGRAPH_CHECKPOINT_DATABASE_URL=postgresql://postgres:pulse@localhost:15433/pulse

CHROMA_DIR=./chroma_db
CHROMA_JD_HISTORY_COLLECTION=jd_history
CHROMA_RESUME_COLLECTION=resume_chunks

# --- Embedding Configuration ---
# Provider: openai | local | deterministic (auto-detect if not set)
# PULSE_EMBEDDING_PROVIDER=openai
# OpenAI-compatible embedding API (uses same key as LLM if not set)
# PULSE_EMBEDDING_API_KEY=
# PULSE_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PULSE_EMBEDDING_MODEL=text-embedding-v3
# For local provider: model name from sentence-transformers
# PULSE_EMBEDDING_MODEL=all-MiniLM-L6-v2
PULSE_EMBED_DIM=256
JD_HISTORY_MIN_SIMILARITY=0.35

PULSE_CORE_MEMORY_PATH=~/.pulse/core_memory.json
PULSE_RECALL_COLLECTION_NAME=pulse_recall_memory
PULSE_ARCHIVAL_COLLECTION_NAME=pulse_archival_memory


# -------------------------
# [模块 4] 材料生成与导出
# -------------------------
MATERIAL_MIN_MATCH_SCORE=60
MATERIAL_EXPORT_DIR=./backend/exports/materials


# -------------------------
# [模块 5] BOSS 浏览器自动化
# -------------------------
# 本地调试建议 false（可见浏览器），容器内建议 true
BOSS_HEADLESS=false
# 建议使用纯英文路径，避免某些浏览器内核在中文路径下启动异常
BOSS_BROWSER_PROFILE_DIR=~/.pulse/boss_browser_profile
BOSS_SCREENSHOT_DIR=./backend/exports/screenshots
BOSS_ENABLE_STEALTH=true
BOSS_ACTION_DELAY_MIN_MS=3000
BOSS_ACTION_DELAY_MAX_MS=5000
BOSS_FETCH_DETAIL=false
FORM_AUTOFILL_TIMEOUT_MS=20000

# -------------------------
# [模块 5.1] Pulse 招聘平台连接器（P0-1）
# -------------------------
# 可选值：openapi / mcp / web_search
# 留空时自动判断：优先 mcp，再 openapi，最后 web_search 降级
PULSE_BOSS_PROVIDER=

# --- OpenAPI connector ---
PULSE_BOSS_OPENAPI_BASE_URL=
PULSE_BOSS_OPENAPI_TOKEN=
PULSE_BOSS_OPENAPI_TIMEOUT_SEC=10
PULSE_BOSS_OPENAPI_AUTH_STATUS_PATH=/auth/status
PULSE_BOSS_OPENAPI_SCAN_PATH=/jobs/scan
PULSE_BOSS_OPENAPI_DETAIL_PATH=/jobs/detail
PULSE_BOSS_OPENAPI_GREET_PATH=/jobs/greet
PULSE_BOSS_OPENAPI_PULL_PATH=/chats/pull
PULSE_BOSS_OPENAPI_REPLY_PATH=/chats/reply
PULSE_BOSS_OPENAPI_MARK_PATH=/chats/mark_processed

# --- MCP connector ---
PULSE_BOSS_MCP_BASE_URL=
PULSE_BOSS_MCP_TOKEN=
PULSE_BOSS_MCP_TIMEOUT_SEC=10
PULSE_BOSS_MCP_SERVER=boss
PULSE_BOSS_MCP_SCAN_TOOL=scan_jobs
PULSE_BOSS_MCP_DETAIL_TOOL=job_detail
PULSE_BOSS_MCP_GREET_TOOL=greet_job
PULSE_BOSS_MCP_PULL_TOOL=pull_conversations
PULSE_BOSS_MCP_REPLY_TOOL=reply_conversation
PULSE_BOSS_MCP_MARK_TOOL=mark_processed
PULSE_BOSS_MCP_CHECK_LOGIN_TOOL=check_login
PULSE_BOSS_MCP_GATEWAY_PORT=8811
PULSE_BOSS_MCP_REPLY_MODE=manual_required
PULSE_BOSS_MCP_GREET_MODE=manual_required
# 建议使用纯英文路径，避免某些浏览器内核在中文路径下启动异常
PULSE_BOSS_BROWSER_PROFILE_DIR=~/.pulse/boss_browser_profile
PULSE_BOSS_BROWSER_HEADLESS=false
PULSE_BOSS_BROWSER_TIMEOUT_MS=20000
PULSE_BOSS_BROWSER_CHANNEL=
PULSE_BOSS_BROWSER_USER_AGENT=
PULSE_BOSS_BROWSER_STEALTH_ENABLED=true
PULSE_BOSS_BROWSER_BLOCK_IFRAME_CORE=true
PULSE_BOSS_LOGIN_CHECK_URL=https://www.zhipin.com/web/geek/chat
PULSE_BOSS_MCP_SCAN_MODE=browser_first
PULSE_BOSS_MCP_PULL_MODE=browser_first
PULSE_BOSS_SEARCH_URL_TEMPLATE=https://www.zhipin.com/web/geek/jobs?query={keyword}
PULSE_BOSS_SCAN_EXTRACT_ATTEMPTS=4
PULSE_BOSS_SEARCH_NEXT_SELECTORS=
PULSE_BOSS_JOB_CARD_SELECTORS=
PULSE_BOSS_JOB_NAV_SELECTORS=
PULSE_BOSS_JOB_SEARCH_INPUT_SELECTORS=
PULSE_BOSS_CHAT_LIST_URL=https://www.zhipin.com/web/geek/chat
PULSE_BOSS_CHAT_ROW_SELECTORS=
PULSE_BOSS_CHAT_TAB_SELECTORS=
PULSE_BOSS_CHAT_URL_TEMPLATE=https://www.zhipin.com/web/geek/chat?conversationId={conversation_id}
PULSE_BOSS_BROWSER_EXECUTOR_RETRY_COUNT=1
PULSE_BOSS_BROWSER_EXECUTOR_RETRY_BACKOFF_MS=700
PULSE_BOSS_RISK_KEYWORDS=验证码,人机验证,访问受限,异常访问,risk,captcha
# 逗号分隔多个 selector，按顺序尝试
PULSE_BOSS_GREET_BUTTON_SELECTORS=
PULSE_BOSS_CHAT_ITEM_SELECTORS=
PULSE_BOSS_CHAT_INPUT_SELECTORS=
PULSE_BOSS_CHAT_SEND_SELECTORS=
PULSE_BOSS_MCP_SCREENSHOT_DIR=./backend/exports/screenshots
PULSE_BOSS_MCP_ACCEPTANCE_TIMEOUT_SEC=25
PULSE_BOSS_MCP_ACCEPTANCE_KEYWORD=AI Agent 实习
PULSE_BOSS_MCP_ACCEPTANCE_STRICT=false
PULSE_BOSS_MCP_ACCEPTANCE_SKIP_WRITE=false
PULSE_BOSS_MCP_ACCEPTANCE_RUN_ID_PREFIX=accept
# legacy env aliases (still supported):
# PULSE_BOSS_MCP_SMOKE_TIMEOUT_SEC
# PULSE_BOSS_MCP_SMOKE_KEYWORD
# PULSE_BOSS_MCP_SMOKE_STRICT
# PULSE_BOSS_MCP_SMOKE_SKIP_WRITE

# --- Reliability / HITL ---
PULSE_BOSS_RETRY_COUNT=2
PULSE_BOSS_RETRY_BACKOFF_SEC=0.8
PULSE_BOSS_RATE_LIMIT_SEC=1.2
PULSE_BOSS_HITL_REQUIRED=true
PULSE_BOSS_CONNECTOR_AUDIT_PATH=./backend/exports/audit/boss_connector_audit.jsonl

# --- Global MCP registry (MCP-first) ---
PULSE_MCP_SERVERS_CONFIG_PATH=config/mcp_servers.yaml
PULSE_MCP_PREFERRED_SERVER=boss


# =========================================================
# [Agent Runtime] 通用 Agent 运行时（OS 内核层）
# =========================================================
# 是否启用 Agent Runtime 持久运行（定时巡检等后台任务）
AGENT_RUNTIME_ENABLED=false
# 心跳间隔（秒），每次 tick 检查所有注册的巡检任务
AGENT_RUNTIME_TICK_SECONDS=15
# 连续错误熔断阈值：某任务连续失败超过此数则自动暂停
AGENT_RUNTIME_MAX_ERRORS=5
# 全局活跃时段（所有巡检任务在非活跃时段不执行）
GUARD_TIMEZONE=Asia/Shanghai
GUARD_ACTIVE_START_HOUR=9
GUARD_ACTIVE_END_HOUR=22
GUARD_WEEKEND_START_HOUR=10
GUARD_WEEKEND_END_HOUR=20

# =========================================================
# [模块巡检] BOSS 打招呼巡检（由 boss_greet 模块读取）
# =========================================================
GUARD_GREET_ENABLED=false
GUARD_GREET_INTERVAL_PEAK=900
GUARD_GREET_INTERVAL_OFFPEAK=1800
GUARD_GREET_KEYWORD=AI Agent 实习

# =========================================================
# [模块巡检] BOSS 对话巡检（由 boss_chat 模块读取）
# =========================================================
GUARD_CHAT_ENABLED=false
GUARD_CHAT_INTERVAL_PEAK=180
GUARD_CHAT_INTERVAL_OFFPEAK=600


# -------------------------
# [模块 6] BOSS 对话 Copilot
# -------------------------
BOSS_CHAT_SOURCE_FIT_THRESHOLD=65
BOSS_CHAT_PROACTIVE_MATCH_THRESHOLD=70
BOSS_CHAT_PROACTIVE_JD_ENRICHMENT=true
BOSS_CHAT_CONFIDENCE_THRESHOLD=0.7

# 自动发送双开关之一（另一个是请求体 auto_execute=true）
BOSS_CHAT_AUTO_EXECUTE_ENABLED=false
# 主动打招呼审计：每条记录保留 JD 摘要最大字符数
BOSS_GREET_AUDIT_JD_MAX_CHARS=2500

# 可选：当 BOSS 页面结构变动时，覆盖输入框/发送按钮选择器
# BOSS_CHAT_INPUT_SELECTORS=.input-area,[contenteditable=true],textarea.chat-input
# BOSS_CHAT_SEND_SELECTORS=.send-message,.send-btn


# -------------------------
# [模块 7] 邮件 IMAP（可选）
# -------------------------
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=


# -------------------------
# [模块 8] 邮件心跳与通知
# -------------------------
EMAIL_HEARTBEAT_ENABLED=false
EMAIL_HEARTBEAT_INTERVAL_SEC=1800
EMAIL_HEARTBEAT_MAX_ITEMS=10
EMAIL_HEARTBEAT_MARK_SEEN=false
EMAIL_HEARTBEAT_NOTIFY_ON_UPDATES=true

EMAIL_SCHEDULE_REMINDER_HOURS=24
EMAIL_SCHEDULE_UPCOMING_DAYS=14

NOTIFY_WEBHOOK_URL=
NOTIFY_MODE=feishu_card
NOTIFY_TIMEOUT_SEC=8


# -------------------------
# [模块 9] 公司情报 Web 搜索（可选）
# -------------------------
WEB_SEARCH_PROVIDER=auto
WEB_SEARCH_TIMEOUT_SEC=10
WEB_SEARCH_MAX_RESULTS=6
TAVILY_API_KEY=


# -------------------------
# [模块 10] 前端提示
# -------------------------
# Next.js 本地开发建议单独写到 frontend/.env.local：
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010
